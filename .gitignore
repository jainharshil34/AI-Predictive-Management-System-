# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── macOS artefacts ───────────────────────────────────────────
.DS_Store
__MACOSX/

# ── IDE ───────────────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace

# ── Streamlit cache ───────────────────────────────────────────
.streamlit/

